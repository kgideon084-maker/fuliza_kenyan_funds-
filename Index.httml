<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Info Portal Website</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
  <h1>Information Portal</h1>
  <p>Simple website with Terms & Conditions and Form</p>
</header>

<nav>
  <a href="#home">Home</a>
  <a href="#terms">Terms</a>
  <a href="#form">Form</a>
</nav>

<section id="home">
  <h2>Welcome</h2>
  <p>This is a simple GitHub Pages website template for learning HTML, CSS and forms.</p>
</section>

<section id="terms">
  <h2>Terms & Conditions</h2>
  <ul>
    <li>All information provided is for educational purposes only.</li>
    <li>Users must not misuse the system.</li>
    <li>We are not responsible for incorrect submissions.</li>
    <li>Data submitted may be stored for demo purposes only.</li>
  </ul>
</section>

<section id="form">
  <h2>Fill the Form</h2>

  <form onsubmit="return handleSubmit(event)">
    <input type="text" placeholder="Full Name" required>
    <input type="email" placeholder="Email Address" required>
    <input type="tel" placeholder="Phone Number" required>
    <textarea placeholder="Your Message"></textarea>
    <button type="submit">Submit</button>
  </form>

  <p id="msg"></p>
</section>

<footer>
  <p>© 2026 Simple GitHub Pages Website</p>
</footer>

<script src="script.js"></script>
</body>
</html>
